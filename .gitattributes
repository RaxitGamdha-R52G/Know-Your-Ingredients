# Force text files to use LF (Linux/macOS style)
*.txt text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.py text eol=lf

# Force Windows-specific files to use CRLF (Windows-style)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files should never be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mp3 binary
*.zip binary
*.exe binary
*.dll binary
*.pdf binary
